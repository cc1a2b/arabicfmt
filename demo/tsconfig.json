{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "arabicfmt": ["../src/index.ts"],
      "arabicfmt/*": ["../src/*/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
